/* ================= TRUE RMS VOLTAGE ==================== */
float readACVoltage(int pin, float calibration) {
  analogSetPinAttenuation(pin, ADC_11db);   // 0–3.3V
  int adc = analogRead(pin);
  float vout = (adc / 4095.0) * 3.3;
  float vac  = vout * calibration;
  if (vac < 10) vac = 0;   // noise cut
  return vac;
}

/* ================= RELAY CONTROL ======================= */
void setRelay(int pin, char feedback) {
  // Turn all relays OFF first
  digitalWrite(RELAY_M1_ON,  HIGH);
  digitalWrite(RELAY_M1_OFF, HIGH);
  digitalWrite(RELAY_M2_ON,  HIGH);
  digitalWrite(RELAY_M2_OFF, HIGH);

  // Activate selected relay
  digitalWrite(pin, LOW);
  activeRelay = pin;
  relayOnTime = millis();
  activeFeedback = feedback;

  Serial.printf("🔌 Relay %d ON for 5 seconds, feedback: %c\n", pin, feedback);
  client.publish("farm/mcu/state", String(feedback).c_str(), true); // Optional general feedback
}

/* ================= MQTT CALLBACK ======================= */
void callback(char* topic, byte* payload, unsigned int length) {
  if (millis() - bootTime < IGNORE_CMD_MS) {
  Serial.println("🚫 Ignoring retained MQTT command after boot");
  return;
}
  String msg;
  for (unsigned int i = 0; i < length; i++)
    msg += (char)payload[i];
  msg.trim();

  Serial.printf("📩 %s → %s\n", topic, msg.c_str());

  // Motor 1
  if (strcmp(topic, "***/m1/cmd") == 0) {
    if (msg == "A") setRelay(RELAY_M1_ON, 'A');   // Motor1 ON
    if (msg == "B") setRelay(RELAY_M1_OFF, 'B');  // Motor1 OFF
  }

  // Motor 2
  if (strcmp(topic, "***/m2/cmd") == 0) {
    if (msg == "C") setRelay(RELAY_M2_ON, 'C');   // Motor2 ON
    if (msg == "D") setRelay(RELAY_M2_OFF, 'D');  // Motor2 OFF
  }
}

